# Copy this file to `.env` and fill in your key.
# `.env` is gitignored, so your key never gets committed.
# app-guru loads this automatically -- no need to `export` anything by hand.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
# Used by `mine` for the pain-point extraction step. This is the ONLY
# credential app-guru needs -- the Reddit search and Google Trends steps
# use no keys at all.
ANTHROPIC_API_KEY=
