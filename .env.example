# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored, so your keys never get committed.
# app-guru loads this automatically -- no need to `export` anything by hand.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
# Used by `mine` for the pain-point extraction step. Required for `mine`.
ANTHROPIC_API_KEY=

# Google Cloud API key with the Custom Search API enabled
# (https://console.cloud.google.com/ -> enable "Custom Search API" -> Credentials)
# Used by `mine` to search Reddit. Required for `mine`.
GOOGLE_SEARCH_API_KEY=

# Your Programmable Search Engine ID (the "Search engine ID" / cx value from
# https://programmablesearchengine.google.com/). Required for `mine`.
GOOGLE_SEARCH_CX=

# Note: `trends` needs none of these -- Google Trends' public endpoint has no key.
