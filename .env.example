# Copy this file to `.env` and fill in your key.
# `.env` is gitignored, so your key never gets committed.
# app-guru loads this automatically -- no need to `export` anything by hand.

# Your Anthropic API key (https://console.anthropic.com/settings/keys)
# Used by `mine` for the pain-point extraction step.
ANTHROPIC_API_KEY=

# Reddit API credentials for `mine` -- create a free "script" app at
# https://www.reddit.com/prefs/apps (type: script). The short string under
# the app name is the client ID; the "secret" field is the client secret.
# (`trends` needs none of these -- Google Trends' public endpoint has no key.)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
